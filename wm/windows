#include <X11/Xlib.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

Display *dpy;
Window root;
Window file_mgr_btn;

int dragging = 0;
int drag_start_x, drag_start_y;
Window drag_win;

int main() {

    dpy = XOpenDisplay(NULL);
    if (!dpy) {
        printf("cannot open display\n");
        exit(1);
    }

    root = DefaultRootWindow(dpy);

    // Create desktop background
    int screen_width = DisplayWidth(dpy, DefaultScreen(dpy));
    int screen_height = DisplayHeight(dpy, DefaultScreen(dpy));
    
    Window bg = XCreateSimpleWindow(
        dpy,
        root,
        0, 0,
        screen_width,
        screen_height,
        0,
        0,
        0x1a1a2e  // dark blue background
    );
    XMapWindow(dpy, bg);
    XLowerWindow(dpy, bg);  // keep it behind other windows

    // Create taskbar at top
    Window taskbar = XCreateSimpleWindow(
        dpy,
        root,
        0, 0,
        screen_width,
        50,
        2,
        0xffffff,  // white border
        0x2d2d44  // dark blue background
    );
    XMapWindow(dpy, taskbar);
    XRaiseWindow(dpy, taskbar);

    // Create file manager button in taskbar
    file_mgr_btn = XCreateSimpleWindow(
        dpy,
        taskbar,
        10, 8,
        34, 34,
        2,
        0x666666,  // gray border
        0x444444   // dark gray background (looks like a cube)
    );
    XMapWindow(dpy, file_mgr_btn);
    XSelectInput(dpy, file_mgr_btn, ButtonPressMask);

    XSelectInput(dpy, root,
        SubstructureRedirectMask |
        SubstructureNotifyMask);

    // launch terminal in background
    if (fork() == 0) {
        // Try different terminals
        execl("/usr/bin/alacritty", "alacritty", NULL);
        execl("/usr/bin/gnome-terminal", "gnome-terminal", NULL);
        execl("/usr/bin/xterm", "xterm", NULL);
        perror("Failed to launch terminal");
        exit(1);
    }

    XEvent ev;

    while (1) {

        XNextEvent(dpy, &ev);

        if (ev.type == MapRequest) {

            Window w = ev.xmaprequest.window;

            XWindowAttributes attr;
            XGetWindowAttributes(dpy, w, &attr);

            int title_height = 50;  // bigger for easier dragging

            Window frame = XCreateSimpleWindow(
                dpy,
                root,
                attr.x,
                attr.y,
                attr.width,
                attr.height + title_height,
                1,
                0,
                0x222222
            );

            XSelectInput(dpy, frame,
                ButtonPressMask |
                ButtonReleaseMask |
                PointerMotionMask);

            XAddToSaveSet(dpy, w);
            XReparentWindow(dpy, w, frame, 0, title_height);

            XMapWindow(dpy, w);
            XMapWindow(dpy, frame);
        }

        if (ev.type == ButtonPress) {

            // Check if file manager button was clicked
            if (ev.xbutton.window == file_mgr_btn) {
                if (fork() == 0) {
                    execl("/usr/bin/dolphin", "dolphin", NULL);
                    execl("/usr/bin/nautilus", "nautilus", NULL);
                    execl("/usr/bin/thunar", "thunar", NULL);
                    exit(1);
                }
            } else {
                dragging = 1;
                drag_win = ev.xbutton.window;

                drag_start_x = ev.xbutton.x_root;
                drag_start_y = ev.xbutton.y_root;
            }
        }

        if (ev.type == MotionNotify && dragging) {

            int dx = ev.xmotion.x_root - drag_start_x;
            int dy = ev.xmotion.y_root - drag_start_y;

            XWindowAttributes attr;
            XGetWindowAttributes(dpy, drag_win, &attr);

            XMoveWindow(
                dpy,
                drag_win,
                attr.x + dx,
                attr.y + dy
            );

            drag_start_x = ev.xmotion.x_root;
            drag_start_y = ev.xmotion.y_root;
        }

        if (ev.type == ButtonRelease) {
            dragging = 0;
        }
    }
}
CC := gcc
CFLAGS := -Wall -Wextra -O2
LDFLAGS := -lX11

SRC_DIR := src
OUT_DIR := build/out
WM := entropywm

SRCS := $(wildcard $(SRC_DIR)/*.c)
OBJS := $(patsubst $(SRC_DIR)/%.c, $(OUT_DIR)/%.o, $(SRCS))

wm_build: $(OUT_DIR)/$(WM)

$(OUT_DIR)/$(WM): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)

$(OUT_DIR)/%.o: $(SRC_DIR)/%.c | $(OUT_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(OUT_DIR):
	mkdir -p $(OUT_DIR)

clean_wm:
	rm -f $(OBJS) $(OUT_DIR)/$(WM)